Task 8: Orchestrate with Docker Compose
docker-compose.yml

YAML
version: '3.8'
services:
  app:
    image: learningwithjunoon/sample-app:v1.0
    ports:
      - "8080:80"
    networks:
      - dev-network
    depends_on:
      - db
  db:
    image: mysql:latest
    environment:
      MYSQL_ROOT_PASSWORD: root
    volumes:
      - db_data:/var/lib/mysql
    networks:
      - dev-network
networks:
  dev-network:
    driver: bridge
volumes:
  db_data:


Deployment: docker-compose up -d
Shutdown: docker-compose down

